{
  "name": "thedigihubs",
  "private": true,
  "version": "0.1.0",
  "description": "Enterprise-grade global B2B procurement marketplace",
  "scripts": {
    "setup": "node scripts/ensure-env.mjs && pnpm install",
    "setup:env": "node scripts/ensure-env.mjs",
    "build": "pnpm db:generate && pnpm -r --if-present build",
    "build:web": "pnpm --filter @thedigihubs/web build",
    "build:api": "pnpm db:generate && pnpm --filter @thedigihubs/api build",
    "build:worker": "pnpm db:generate && pnpm --filter @thedigihubs/worker build",
    "dev:web": "pnpm --filter @thedigihubs/web dev",
    "dev:api": "pnpm --filter @thedigihubs/api start:dev",
    "dev:worker": "pnpm --filter @thedigihubs/worker dev",
    "db:doctor": "node scripts/ensure-env.mjs && node scripts/db-doctor.mjs",
    "db:generate": "node scripts/ensure-env.mjs && pnpm --filter @thedigihubs/database prisma:generate",
    "db:migrate:deploy": "node scripts/ensure-env.mjs && pnpm --filter @thedigihubs/database prisma:migrate:deploy",
    "db:push": "node scripts/ensure-env.mjs && pnpm --filter @thedigihubs/database prisma:push",
    "db:seed": "node scripts/ensure-env.mjs && pnpm --filter @thedigihubs/database prisma:seed",
    "db:backup": "node scripts/ensure-env.mjs && node scripts/db-backup.mjs",
    "db:restore": "node scripts/ensure-env.mjs && node scripts/db-restore.mjs",
    "docker:build": "node scripts/ensure-env.mjs && docker compose build",
    "docker:up": "node scripts/ensure-env.mjs && docker compose up --build",
    "docker:up:detached": "node scripts/ensure-env.mjs && docker compose up --build -d",
    "docker:refresh": "node scripts/ensure-env.mjs && docker compose up --build --force-recreate -d",
    "docker:web:refresh": "node scripts/ensure-env.mjs && docker compose up --no-build --force-recreate -d api web",
    "docker:web:hard-refresh": "node scripts/ensure-env.mjs && node scripts/hard-refresh-web.mjs",
    "docker:web:doctor": "node scripts/ensure-env.mjs && node scripts/web-doctor.mjs",
    "docker:bootstrap": "pnpm docker:up:detached && pnpm docker:db:setup",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:ps": "docker compose ps",
    "docker:rebuild": "pnpm docker:down && pnpm docker:build",
    "docker:db:setup": "node scripts/ensure-env.mjs && pnpm db:doctor && pnpm db:generate && pnpm db:push && pnpm db:seed",
    "docker:db:reset": "node scripts/ensure-env.mjs && node scripts/reset-docker-db.mjs && pnpm docker:db:setup",
    "lint": "pnpm -r --if-present lint",
    "typecheck": "pnpm db:generate && pnpm -r --if-present typecheck",
    "smoke:web": "node scripts/ensure-env.mjs && node scripts/smoke-web.mjs",
    "smoke:api": "node scripts/ensure-env.mjs && node scripts/smoke-api.mjs",
    "smoke:all": "pnpm smoke:web && pnpm smoke:api"
  },
  "packageManager": "pnpm@9.15.0"
}
