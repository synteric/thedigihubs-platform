      "type": "shell",
      "command": "pnpm docker:bootstrap",
      "problemMatcher": []
    },
    {
      "label": "TheDigiHubs: Docker rebuild",
      "type": "shell",
      "command": "pnpm docker:rebuild",
      "problemMatcher": []
    },
    {
      "label": "TheDigiHubs: Docker down",
      "type": "shell",
      "command": "pnpm docker:down",
      "problemMatcher": []
    },
    {
      "label": "TheDigiHubs: Docker logs",
      "type": "shell",
      "command": "pnpm docker:logs",
      "isBackground": true,
      "problemMatcher": []
    },
    {
      "label": "TheDigiHubs: Setup database in Docker",
      "type": "shell",
      "command": "pnpm docker:db:setup",
      "problemMatcher": []
    }
